VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "교육자료"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = True
Option Explicit
Private Sub SearchBox_Change()
    Dim celTarget As Range
    Set celTarget = [U3]
    With Me.SearchBox
    If .ListIndex = -1 Then
        celTarget = IIf(.value = "", "", "%" & .value & "%")
    Else
        celTarget = .value
    End If
    End With
End Sub
Private Sub SearchBox_DropButtonClick()
    If Me.SearchBox.ListIndex = -1 Then
        Call FormSearchFilter
    End If
End Sub
Private Sub SearchBox_KeyDown(ByVal KeyCode As MSForms.ReturnInteger, ByVal Shift As Integer)
    If KeyCode = 13 Then '엔터 키(KeyCode = 13) 입력 시 이벤트 처리
        Call RunShpMacro("SEARCH")
    End If
End Sub
Private Sub Worksheet_SelectionChange(ByVal Target As Range)

    Dim t As Range, rng As Range
    Set t = Target(1, 1)
    Set rng = Intersect(t, Union(Range("T_교육자료[챕터명]"), Range("TS_교육자료_시즌챕터[챕터명]")))

    If Not rng Is Nothing Then

        Dim tbl As ListObject
        Set tbl = ThisWorkbook.Worksheets("DB_챕터").ListObjects(1)

        Dim strSeason As String
        strSeason = t.Offset(, intOffset(t, "시즌코드"))

        If strSeason <> "" Then
            Dim arr As Variant
            arr = TblFindVals_MC(tbl, "명칭", "시즌코드", "=", strSeason)
            
            cl.sht_UnLock
            Call ValidationList(t, arr)
            cl.sht_Lock
            
        End If
    End If
    
End Sub
